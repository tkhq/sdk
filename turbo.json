{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": [
        "build/**",
        ".cache/**",
        ".vercel/**",
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig.json",
        "!dist",
        "!build",
        "!.next",
        "!.vercel",
        "!**/*.md"
      ],
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": [
        "build/**",
        ".vercel/**",
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    }
  },
  "globalPassThroughEnv": [
    "API_PUBLIC_KEY",
    "API_PRIVATE_KEY",
    "BASE_URL",
    "ORGANIZATION_ID",
    "PRIVATE_KEY_ID",
    "EXPECTED_PRIVATE_KEY_ETH_ADDRESS",
    "EXPECTED_PRIVATE_KEY_ETH_ADDRESS_2",
    "EXPECTED_WALLET_ACCOUNT_ETH_ADDRESS",
    "EXPECTED_WALLET_ACCOUNT_ETH_ADDRESS_2",
    "BANNED_TO_ADDRESS",
    "SOLANA_TEST_ORG_API_PRIVATE_KEY",
    "WALLET_ID"
  ]
}
