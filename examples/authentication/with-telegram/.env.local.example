API_PUBLIC_KEY="<Turnkey API Public Key (that starts with 02 or 03)>"
API_PRIVATE_KEY="<Turnkey API Private Key>"
NEXT_PUBLIC_ORGANIZATION_ID="<Turnkey organization ID>"
NEXT_PUBLIC_BASE_URL="https://api.turnkey.com"

# Telegram bot credentials — get from @BotFather: /mybots → select bot → API Token
# Bot token format: 123456789:ABCdef... → ID is "123456789", secret is "ABCdef..."
NEXT_PUBLIC_TELEGRAM_BOT_ID="<Telegram bot numeric ID>"
TELEGRAM_BOT_SECRET="<Telegram bot secret (everything after the colon in the bot token)>"

# The redirect URI registered with your bot in @BotFather (must match exactly).
# Telegram does not accept localhost — use a tunnel (e.g. ngrok) for local dev.
# See README step 4 for setup instructions.
NEXT_PUBLIC_REDIRECT_URI="https://your-tunnel.ngrok-free.app/callback"
