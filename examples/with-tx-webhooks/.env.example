API_PUBLIC_KEY="<Turnkey API Public Key (starts with 02 or 03)>"
API_PRIVATE_KEY="<Turnkey API Private Key>"
ORGANIZATION_ID="<Turnkey organization ID>"
BASE_URL="https://api.turnkey.com"

# Public URL for BALANCE_CONFIRMED_UPDATES webhook (used by register-webhook:balance)
BALANCE_WEBHOOK_URL="https://<your-ngrok-subdomain>.ngrok-free.app/webhook/balance-updates"
BALANCE_WEBHOOK_NAME="balance-confirmed-webhook"

# Public URL for SEND_TRANSACTION_STATUS_UPDATES webhook (used by register-webhook:tx-status)
TX_STATUS_WEBHOOK_URL="https://<your-ngrok-subdomain>.ngrok-free.app/webhook/tx-updates"
TX_STATUS_WEBHOOK_NAME="tx-status-webhook"

# Optional: override the JSON-RPC URL used for unsponsored ETH sends.
# If omitted, the example uses a per-network default public RPC.
ETH_RPC_URL=""

# Optional: override the JSON-RPC URL used for unsponsored Solana sends.
# If omitted, the example uses a per-network default public RPC.
SOLANA_RPC_URL=""

# Frontend defaults
NEXT_PUBLIC_DEFAULT_ADDRESS="0x0000000000000000000000000000000000000000"
NEXT_PUBLIC_DEFAULT_CAIP2="eip155:8453"
