    "next": "15.5.18",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.3.1",
    "@types/react": "18.2.14",
    "@types/react-dom": "18.2.6",
    "tsx": "^3.12.7",
    "typescript": "5.4.3"
  }
