# Admin credential — used by setup.ts to provision the org
API_PUBLIC_KEY="<Turnkey API Public Key (that starts with 02 or 03)>"
API_PRIVATE_KEY="<Turnkey API Private Key>"
ORGANIZATION_ID="<Turnkey organization ID>"
BASE_URL="https://api.turnkey.com"

# Automation user credential — used by demo.ts for signing sweeps
# These are produced by setup.ts if the user is created programmatically,
# or filled in manually if you create the user via the Turnkey dashboard.
AUTOMATION_API_PUBLIC_KEY=""
AUTOMATION_API_PRIVATE_KEY=""

# Optional: override the default Sepolia RPC URL
# SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
