# Turnkey credentials (for future Turnkey integration)
API_PUBLIC_KEY=
API_PRIVATE_KEY=
BASE_URL=https://api.turnkey.com
ORGANIZATION_ID=

# Spark wallet configuration
# Optional: provide an existing BIP39 mnemonic to restore a wallet.
# Leave blank to auto-generate a new one on first run.
MNEMONIC=

# Optional: target Spark address to send a test transfer to.
RECEIVER_SPARK_ADDRESS=

# Network: MAINNET or REGTEST (default: REGTEST)
SPARK_NETWORK=REGTEST
