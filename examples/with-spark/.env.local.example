# Turnkey credentials
BASE_URL=https://api.turnkey.com
ORGANIZATION_ID=
API_PUBLIC_KEY=
API_PRIVATE_KEY=

# Network: MAINNET or REGTEST (hosted E2E uses REGTEST)
SPARK_NETWORK=REGTEST

# One-wallet scripts: from `pnpm run setup` output
TURNKEY_WALLET_ID=
TURNKEY_SPARK_ADDRESS=
TURNKEY_ECDSA_ADDRESS=
IDENTITY_PUBLIC_KEY_HEX=

# One-wallet hosted regtest deposit: from `pnpm run setup:l1` output
TURNKEY_L1_BTC_ADDRESS=
TURNKEY_L1_BTC_PUBLIC_KEY_HEX=

# One-wallet transfer / token-transfer / withdraw scripts
RECEIVER_SPARK_ADDRESS=
WITHDRAW_BTC_ADDRESS=

# Hosted REGTEST E2E: from `pnpm run setup:e2e` output
SENDER_TURNKEY_WALLET_ID=
SENDER_TURNKEY_SPARK_ADDRESS=
SENDER_TURNKEY_ECDSA_ADDRESS=
SENDER_IDENTITY_PUBLIC_KEY_HEX=
SENDER_TURNKEY_L1_BTC_ADDRESS=
SENDER_TURNKEY_L1_BTC_PUBLIC_KEY_HEX=

RECEIVER_TURNKEY_WALLET_ID=
RECEIVER_TURNKEY_SPARK_ADDRESS=
RECEIVER_TURNKEY_ECDSA_ADDRESS=
RECEIVER_IDENTITY_PUBLIC_KEY_HEX=
RECEIVER_TURNKEY_L1_BTC_ADDRESS=
RECEIVER_TURNKEY_L1_BTC_PUBLIC_KEY_HEX=

# Hosted regtest L1 deposit settings
L1_DEPOSIT_FEE_SATS=500
L1_DEPOSIT_AMOUNT_SATS=
L1_DEPOSIT_TXID=
L1_FUNDING_TIMEOUT_MS=60000
L1_FUNDING_POLL_MS=5000
L1_DEPOSIT_CONFIRMATION_TIMEOUT_MS=300000
L1_DEPOSIT_CONFIRMATION_POLL_MS=5000
TRANSFER_CLAIM_TIMEOUT_MS=120000
TRANSFER_CLAIM_POLL_MS=3000
# Hosted REGTEST Electrs uses Spark SDK default basic auth automatically.
# Override only if you point SPARK_REGTEST_ELECTRS_URL at another protected endpoint.
SPARK_REGTEST_ELECTRS_USER=
SPARK_REGTEST_ELECTRS_PASSWORD=

# Optional amounts
DEPOSIT_AMOUNT_SATS=100000
TRANSFER_AMOUNT_SATS=
# Empty withdraws this E2E run's transfer amount.
WITHDRAW_AMOUNT_SATS=
WITHDRAW_EXIT_SPEED=FAST

# Lightning receive / send
LIGHTNING_AMOUNT_SATS=1000
LIGHTNING_MEMO=Turnkey Spark Lightning receive
LIGHTNING_EXPIRY_SECONDS=
LIGHTNING_INCLUDE_SPARK_ADDRESS=false
LIGHTNING_INCLUDE_SPARK_INVOICE=false
LIGHTNING_INVOICE=
LIGHTNING_MAX_FEE_SATS=1000
LIGHTNING_AMOUNT_SATS_TO_SEND=
LIGHTNING_IDEMPOTENCY_KEY=
LIGHTNING_SETTLEMENT_TIMEOUT_MS=120000
LIGHTNING_SETTLEMENT_POLL_MS=3000
# Optional wallet prefixes for the one-shot Lightning scripts.
# Use RECEIVER_ for lightning:receive and SENDER_ for lightning:send after setup:e2e.
LIGHTNING_RECEIVER_ENV_PREFIX=
LIGHTNING_SENDER_ENV_PREFIX=
CLAIM_ENV_PREFIX=
