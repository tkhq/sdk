# Turnkey parent org credentials (used for OTP flow and suborg creation)
NEXT_PUBLIC_BASE_URL=https://api.turnkey.com
NEXT_PUBLIC_ORGANIZATION_ID=<your-parent-org-id>
API_PUBLIC_KEY=<your-admin-api-public-key>
API_PRIVATE_KEY=<your-admin-api-private-key>

# Separate cosigner key — added as a root user in every sub-org at creation time.
# Create a dedicated API key in the Turnkey dashboard and use it here.
# Keeping it separate limits blast radius: a compromised admin key cannot approve
# activities, and a compromised cosigner key cannot create sub-orgs or manage users.
COSIGNER_API_PUBLIC_KEY=<your-cosigner-api-public-key>
COSIGNER_API_PRIVATE_KEY=<your-cosigner-api-private-key>

# Public URL for the webhook receiver — use ngrok for local dev:
#   npx ngrok http 3000
# Then set this to: https://<your-ngrok-id>.ngrok-free.app/api/webhook/activity-updates
WEBHOOK_URL=https://<your-ngrok-subdomain>.ngrok-free.app/api/webhook/activity-updates
