# Turnkey parent org + Auth Proxy
NEXT_PUBLIC_ORGANIZATION_ID="<your Turnkey parent org ID>"
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID="<your Auth Proxy config ID>"

# Agent API key pair (pre-generate with `turnkey generate api-key` or any P-256 tool)
# The public key is registered in the sub-org as a non-root user by the user's own session key at setup time.
NEXT_PUBLIC_AGENT_API_PUBLIC_KEY="<compressed P-256 public key, 66 hex chars, no 0x>"
AGENT_API_PRIVATE_KEY="<P-256 private key, used by pnpm agent CLI to stamp signing requests>"

# Admin API key — only needed for pnpm webhook -register / -update
API_PUBLIC_KEY="<admin API key public>"
API_PRIVATE_KEY="<admin API key private>"

# Sepolia recipient addresses for policy enforcement demo
NEXT_PUBLIC_ALLOWED_RECIPIENT="<Ethereum address the agent can sign to freely>"
NEXT_PUBLIC_APPROVAL_RECIPIENT="<Ethereum address that requires your approval>"

# Webhook delivery URL — set to your ngrok tunnel + the path below
WEBHOOK_URL="https://<your-ngrok-id>.ngrok-free.app/api/webhook/activity-updates"
