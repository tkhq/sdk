# Copy to .env.local and fill in. Never commit .env.local.

# --- Turnkey ---
ORGANIZATION_ID=
API_PUBLIC_KEY=
API_PRIVATE_KEY=

# Ed25519 account public key (hex), created in the Turnkey app.
CARDANO_PUBLIC_KEY=

# --- Network ---
NETWORK=preprod        # "preprod" | "preview" | "mainnet"

# --- Cardano provider ---
# Koios is free and public — no key/signup needed (used automatically).
