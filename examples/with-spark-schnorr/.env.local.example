# Spark wallet configuration
# BIP39 mnemonic to restore an existing wallet.
# Leave blank to auto-generate one on first run.
MNEMONIC="captain deny globe oak fragile cargo tackle unusual inner ranch distance apart"

# Network: MAINNET or REGTEST (default: REGTEST)
SPARK_NETWORK=REGTEST

# Optional: Spark address to send a test transfer to (for regtest acceptance test)
RECEIVER_SPARK_ADDRESS=

# -------------------------------------------------------------------
# Optional: Turnkey credentials for signature comparison
# Set these if you want to compare native Spark SDK Schnorr signatures
# against Turnkey's signRawPayload output for the same key.
# -------------------------------------------------------------------
BASE_URL=http://localhost:8081
ORGANIZATION_ID=358424ef-becc-4b24-ba7a-7b7dba2faa21
API_PUBLIC_KEY=037f919f7127c9f3c9aa32e7dfe9d5a92a382ee824f1b9ee1a3c102b31d215677c
API_PRIVATE_KEY=24649001cf4b7bc518b0a21e1a944fae8dd75f3b780e17972bfa27d9e5223066

# The Turnkey address / key identifier that holds the same private key
# as the Spark identity key derived from the mnemonic above.
TURNKEY_IDENTITY_ADDRESS=spark1pgssy3ntvwya0wgycdt99mwqgq9ytf486ry8rd9r4zdpuegrdc0uksr930hyq6
# Compressed 33-byte public key (hex) of the identity key held in Turnkey.
# Used by TurnkeySparkSigner.getIdentityPublicKey() without a round-trip.
IDENTITY_PUBLIC_KEY_HEX=02466b6389d7b904c35652edc0400a45a6a7d0c871b4a3a89a1e65036e1fcb4065

# -------------------------------------------------------------------
# Optional: Bitcoin P2TR transaction signing test (regtest)
# Fund the P2TR deposit address printed at startup, then fill these in.
# -------------------------------------------------------------------
UTXO_TXID=
UTXO_VOUT=0
UTXO_VALUE=
DESTINATION_ADDRESS=
FEE_SATS=300

# Amount in sats to send in the Spark transfer test (default: 1000)
TRANSFER_AMOUNT_SATS=1000
