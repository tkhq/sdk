API_PUBLIC_KEY="<Turnkey API Public Key (starts with 02 or 03)>"
API_PRIVATE_KEY="<Turnkey API Private Key>"
ORGANIZATION_ID="<Turnkey organization ID>"
BASE_URL="https://api.turnkey.com"

# Public URL that Turnkey will call for BALANCE_CONFIRMED_UPDATES
WEBHOOK_URL="https://<your-ngrok-subdomain>.ngrok-free.app/webhook/balance-updates"
WEBHOOK_NAME="balance-confirmed-webhook-preprod"

# Optional: override the JSON-RPC URL used for unsponsored ETH sends.
# If omitted, the example uses a per-network default public RPC.
ETH_RPC_URL=""

# Frontend defaults
NEXT_PUBLIC_DEFAULT_ADDRESS="0x0000000000000000000000000000000000000000"
NEXT_PUBLIC_DEFAULT_CAIP2="eip155:8453"
