TURNKEY_BASE_URL="https://api.turnkey.com"

# Parent org — used only by the one-time `pnpm deploy-vault` step
PARENT_ORGANIZATION_ID="<parent org ID>"
PARENT_API_PUBLIC_KEY="<parent org API public key (starts with 02 or 03)>"
PARENT_API_PRIVATE_KEY="<parent org API private key>"

# Client performance fee, taken on yield. The fee wallet must be a
# Turnkey-managed wallet address in the parent org.
CLIENT_FEE_BPS="2000"
CLIENT_FEE_WALLET="0x..."

# Root-user API key for the sub-org created by `pnpm create-sub-org`
# (defaults to the parent API key when unset)
SUB_ORG_API_PUBLIC_KEY="<P-256 public key, e.g. from \`turnkey generate api-key\`>"
# Optional: adds a second sub-org root user with this email, enabling
# dashboard access to the sub-org via email auth
SUB_ORG_EMAIL=""

# Demo org — used by `pnpm demo` (can be the same as the parent org)
TURNKEY_ORGANIZATION_ID="<demo org ID>"
TURNKEY_API_PUBLIC_KEY="<demo org API public key>"
TURNKEY_API_PRIVATE_KEY="<demo org API private key>"

# Turnkey wallet address in the demo org, funded on Base with USDC + ETH for gas
SIGN_WITH="0x..."

CHAIN_CAIP2="eip155:8453"
# Underlying asset to look up in the vault catalog (default: USDC on Base)
ASSET_CAIP19="eip155:8453/erc20:0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
# Vault to deploy/deposit into; leave empty to pick the top catalog vault at
# deploy time. Must come from the EarnVaults catalog (Morpho VaultV2 — v1
# MetaMorpho vaults are not wrappable).
VAULT_ADDRESS=
DEPOSIT_ASSETS="1000000"  # 1 USDC (6 decimals)
WITHDRAW_ASSETS="500000"  # 0.5 USDC
SPONSOR="false"
