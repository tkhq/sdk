  "devDependencies": {
    "@actions/core": "~3.0.1",
    "@babel/preset-env": "7.20.2",
    "@babel/preset-flow": "7.23.3",
    "@babel/preset-react": "7.18.6",
    "@babel/preset-typescript": "7.18.6",
    "@mempool/mempool.js": "~3.0.0",
