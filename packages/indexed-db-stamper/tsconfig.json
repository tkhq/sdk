{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2020"],
    "types": ["jest", "node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.cache/.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.json",
    "src/**/*.mts",
    "src/**/*.mjs"
  ],
  "exclude": ["dist", "node_modules"]
}
