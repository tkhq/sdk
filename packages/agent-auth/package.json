{
  "name": "@turnkey/agent-auth",
  "version": "0.1.0",
  "description": "Provision isolated, policy-gated cryptographic identities for AI agents using Turnkey",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c ../../rollup.config.base.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf ./dist ./.cache",
    "test": "jest"
  },
  "peerDependencies": {
    "@turnkey/sdk-server": "workspace:*"
  },
  "dependencies": {
    "@turnkey/api-key-stamper": "workspace:*",
    "@turnkey/crypto": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tkhq/sdk",
    "directory": "packages/agent-auth"
  }
}
