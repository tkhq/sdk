{
  "name": "@turnkey/oss",
  "private": true,
  "description": "Public monorepo for Turnkey SDK & API",
  "scripts": {
    "changeset": "changeset",
    "version": "pnpm run --r --filter \"./packages/**\" version",
    "build-all": "pnpm run --r --filter \"./packages/**\" build",
    "build:watch": "tsc --build tsconfig.mono.json --watch",
    "build": "turbo build",
    "clean": "turbo clean",
    "generate-docs": "typedoc --options typedoc.json",
    "clean-all": "turbo clean",
    "prettier-all:check": "prettier --check \"**/*.{css,html,js,json,md,ts,tsx,yaml,yml,mjs}\" --ignore-path ./.prettierignore",
    "prettier-all:write": "prettier --write \"**/*.{css,html,js,json,md,ts,tsx,yaml,yml,mjs}\" --ignore-path ./.prettierignore",
    "prettier-codegen:write": "prettier --write \"packages/{core,sdk-browser,sdk-server,sdk-types}/src/**/*.{css,html,js,json,md,ts,tsx,yaml,yml,mjs}\"",
    "test-all": "pnpm run -r --no-bail test",
    "test": "turbo test",
    "typecheck-all": "pnpm run -r typecheck",
    "typecheck": "turbo typecheck",
    "codegen-all": "pnpm run -r codegen",
    "prepare-release": "pnpm changeset version && pnpm run version"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": "^8.0.0",
    "pnpm": "10.6.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.5",
    "@jest/globals": "29.4.3",
    "@jest/types": "29.4.3",
    "@microsoft/tsdoc": "^0.15.1",
    "@microsoft/tsdoc-config": "^0.17.1",
    "@rollup/plugin-alias": "5.1.1",
    "@rollup/plugin-babel": "5.3.0",
    "@rollup/plugin-node-resolve": "16.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@rollup/plugin-url": "8.0.2",
    "@tsconfig/node16-strictest": "^1.0.4",
    "@turnkey/jest-config": "workspace:*",
    "@types/node": "^18.18.2",
    "jest": "29.4.3",
    "prettier": "^3.4.2",
    "rimraf": "^3.0.2",
    "rollup": "4.59.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-externals": "^6.1.2",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-preserve-directives": "^1.1.2",
    "tsx": "^3.12.7",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.1",
    "typedoc-plugin-markdown": "^4.6.0",
    "typescript": "5.4.3"
  },
  "packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6",
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-3194"
      ]
    }
  }
}
